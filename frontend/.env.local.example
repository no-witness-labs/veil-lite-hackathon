# Copy to .env.local to point the Vite dev/preview server at Canton DevNet.
# Leave unset for the local auth-disabled sandbox at http://127.0.0.1:6864.
#
# The client secret stays server-side in Vite middleware; it is never exposed to
# browser code because these variables are intentionally not VITE_* variables.
VEIL_LEDGER_TARGET=https://ledger-api.validator.devnet.sandbox.fivenorth.io
VEIL_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
VEIL_OIDC_CLIENT_ID=validator-devnet-m2m
VEIL_OIDC_CLIENT_SECRET=<your-client-secret>
VEIL_OIDC_AUDIENCE=validator-devnet-m2m
VEIL_OIDC_SCOPE=daml_ledger_api

# The Daml JSON Ledger API user the token maps to on the shared validator.
VEIL_LEDGER_USER_ID=6

# Required by Vercel's /ledger-config.json function. Locally, bootstrap-devnet.py
# writes these values into frontend/public/ledger-config.json instead.
VEIL_PARTY_LENDER=veilLiteLender::<participant-fingerprint>
VEIL_PARTY_BORROWER=veilLiteBorrower::<participant-fingerprint>
VEIL_PARTY_REGULATOR=veilLiteRegulator::<participant-fingerprint>
VEIL_PARTY_OUTSIDER=veilLiteOutsider::<participant-fingerprint>

# Optional for short manual tests only. Prefer OIDC client credentials above so
# the proxy can refresh the token automatically.
# VEIL_DEVNET_ACCESS_TOKEN=<short-lived-access-token>
