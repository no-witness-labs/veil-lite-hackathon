-- Tests for the token-standard Veil loan flow, driving the OpenZeppelin simple-token implementation
-- (SimpleTokenRules / SimpleHolding) as the concrete CIP-056 registry behind the standard interfaces.
--
-- Canonical demo numbers: principal 100, interest 5, repayment 105, collateral 150, 90% threshold.
module Veil.Test where

import DA.Date (date, Month(..))
import DA.Time (time, addRelTime, days)
import DA.Optional (isNone)
import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV1
import Splice.Api.Token.AllocationV1
import Splice.Api.Token.AllocationInstructionV1

-- Use the OpenZeppelin simple-token implementation as the concrete CIP-056 registry.
import SimpleToken.Holding (SimpleHolding(..))
import SimpleToken.Rules (SimpleTokenRules(..))

import Veil

t0 : Time
t0 = time (date 2026 Jan 1) 0 0 0

deadline : Time
deadline = time (date 2026 Dec 31) 0 0 0

emptyExtraArgs : ExtraArgs
emptyExtraArgs = ExtraArgs with context = emptyChoiceContext; meta = emptyMetadata

-- | Mint a standard (OZ) holding; admin + owner co-sign.
mintHolding : Party -> Party -> InstrumentId -> Decimal -> Script (ContractId Holding)
mintHolding admin owner instrumentId amount = do
  cid <- submit (actAs [admin, owner]) $ createCmd SimpleHolding with
    admin; owner; instrumentId; amount; meta = emptyMetadata
  pure (toInterfaceContractId @Holding cid)

-- | Build a one-leg allocation specification.
mkSpec : Party -> Party -> Party -> InstrumentId -> Decimal -> AllocationSpecification
mkSpec sender receiver executor instrumentId amount =
  AllocationSpecification with
    settlement = SettlementInfo with
      executor
      settlementRef = Reference with id = "veil-loan"; cid = None
      requestedAt = t0
      allocateBefore = deadline
      settleBefore = deadline
      meta = emptyMetadata
    transferLegId = "leg"
    transferLeg = TransferLeg with
      sender; receiver; amount; instrumentId; meta = emptyMetadata

-- | Fund an allocation through the OZ AllocationFactory (admin authority via the factory contract).
fundAllocation : Party -> ContractId SimpleTokenRules -> AllocationSpecification -> [ContractId Holding] -> Script (ContractId Allocation)
fundAllocation admin rulesCid spec inputs = do
  let afCid = toInterfaceContractId @AllocationFactory rulesCid
  res <- submit (actAs [admin, spec.transferLeg.sender]) $
    exerciseCmd afCid AllocationFactory_Allocate with
      expectedAdmin = admin
      allocation = spec
      requestedAt = t0
      inputHoldingCids = inputs
      extraArgs = emptyExtraArgs
  case res.output of
    AllocationInstructionResult_Completed allocCid -> pure allocCid
    _ -> abort "allocation did not complete"

-- | Unlocked balance of an instrument owned by a party (locked escrow excluded).
balanceOf : Party -> InstrumentId -> Script Decimal
balanceOf p instrumentId = do
  hs <- queryInterface @Holding p
  pure $ sum [ hv.amount | (_, Some hv) <- hs, hv.owner == p, hv.instrumentId == instrumentId, isNone hv.lock ]

data Env = Env with
  registry : Party; lender : Party; borrower : Party; regulator : Party; outsider : Party
  operator : Party
  rulesCid : ContractId SimpleTokenRules
  usd : InstrumentId; tbill : InstrumentId

setup : Script Env
setup = do
  setTime t0
  registry <- allocateParty "Registry"
  operator <- allocateParty "Operator"
  lender <- allocateParty "Lender"
  borrower <- allocateParty "Borrower"
  regulator <- allocateParty "Regulator"
  outsider <- allocateParty "Outsider"
  rulesCid <- submit registry $ createCmd SimpleTokenRules with
    admin = registry; supportedInstruments = ["USD", "TBILL"]
  let usd = InstrumentId with admin = registry; id = "USD"
      tbill = InstrumentId with admin = registry; id = "TBILL"
  pure Env with registry; lender; borrower; regulator; outsider; operator; rulesCid; usd; tbill

-- | Create the canonical loan offer against a funded principal allocation (lender signs; the operator
-- is only a field, so the custodian never sees the offer).
makeOffer : Env -> ContractId Allocation -> Script (ContractId LoanOffer)
makeOffer Env{..} cashAlloc =
  submit lender $ createCmd LoanOffer with
    lender; borrower; regulator; operator
    cashAllocationCid = cashAlloc
    cashInstrumentId = usd
    principal = 100.0; interest = 5.0
    collateralInstrumentId = tbill; collateralQuantity = 150.0
    liquidationThresholdLtv = 90.0; maturity = deadline

-- | Borrower escrows 150 collateral with the operator: fund a borrower -> operator allocation, execute
-- it into the operator's holding, and wrap it in an Escrow (borrower + operator co-sign). The custodian
-- sees only the collateral here — never the loan.
escrowCollateral : Env -> Script (ContractId Escrow)
escrowCollateral Env{..} = do
  borrowerColl <- mintHolding registry borrower tbill 150.0
  collAlloc <- fundAllocation registry rulesCid (mkSpec borrower operator operator tbill 150.0) [borrowerColl]
  res <- submit (actAs [borrower, operator]) $
    exerciseCmd collAlloc Allocation_ExecuteTransfer with extraArgs = emptyExtraArgs
  escrowHoldingCid <- case res.receiverHoldingCids of
    (c :: _) -> pure c
    [] -> abort "escrow execute produced no holding"
  submit (actAs [borrower, operator]) $ createCmd Escrow with
    operator; borrower; lender; regulator
    escrowCollateralCid = escrowHoldingCid
    collateralFactoryCid = toInterfaceContractId @AllocationFactory rulesCid
    collateralInstrumentId = tbill
    collateralQuantity = 150.0

-- | Offer + escrow + accept, returning the active loan.
originate : Env -> Script (ContractId Loan)
originate env@Env{..} = do
  lenderCash <- mintHolding registry lender usd 100.0
  _borrowerCash <- mintHolding registry borrower usd 105.0
  cashAlloc <- fundAllocation registry rulesCid (mkSpec lender borrower lender usd 100.0) [lenderCash]
  offerCid <- makeOffer env cashAlloc
  escrowCid <- escrowCollateral env
  submit borrower $ exerciseCmd offerCid Accept with
    escrowCid
    cashExtraArgs = emptyExtraArgs

-- Full lifecycle: offer -> escrow -> accept -> repay, with privacy + double-entry assertions.
testFullLifecycle : Script ()
testFullLifecycle = do
  env@Env{..} <- setup
  loanCid <- originate env

  -- Principal delivered: borrower holds 105 (seed) + 100 (principal) = 205 USD spendable.
  balanceOf borrower usd >>= \b -> assertMsg "borrower USD after draw" (b == 205.0)
  balanceOf lender usd >>= \b -> assertMsg "lender USD after draw" (b == 0.0)
  balanceOf borrower tbill >>= \b -> assertMsg "borrower holds no collateral (escrowed)" (b == 0.0)

  -- Privacy: outsider sees no loan and no holdings; regulator (observer) sees the loan.
  outsiderLoans <- query @Loan outsider
  assertMsg "outsider sees no loan" (null outsiderLoans)
  outsiderHoldings <- queryInterface @Holding outsider
  assertMsg "outsider sees no holdings" (null outsiderHoldings)
  regLoans <- query @Loan regulator
  assertMsg "regulator sees the loan" (length regLoans == 1)

  -- Borrower repays exactly 105 from the seed holding (exact-amount: no over-disclosure).
  [seed105] <- pure . map fst =<< queryFilter @SimpleHolding borrower
    (\h -> h.owner == borrower && h.instrumentId == usd && h.amount == 105.0)
  repayAlloc <- fundAllocation registry rulesCid (mkSpec borrower lender borrower usd 105.0)
    [toInterfaceContractId @Holding seed105]
  -- readAs [operator, registry]: the escrow holding (operator-owned) + the factory (registry-owned)
  -- must be visible for the collateral release.
  closedCid <- submit (actAs [borrower] <> readAs [operator, registry]) $ exerciseCmd loanCid Repay with
    repayAllocationCid = repayAlloc
    repayExtraArgs = emptyExtraArgs
    collateralExtraArgs = emptyExtraArgs

  -- Double-entry: lender ends with 105 (principal + interest); collateral returned to borrower.
  balanceOf lender usd >>= \b -> assertMsg "lender USD after repay" (b == 105.0)
  balanceOf borrower tbill >>= \b -> assertMsg "collateral returned" (b == 150.0)
  closed <- queryContractId regulator closedCid
  assertMsg "regulator sees Repaid record" (optional False (\c -> c.reason == "Repaid") closed)
  outsiderClosed <- query @LoanClosed outsider
  assertMsg "outsider sees no closed loan" (null outsiderClosed)

-- Custodian privacy: the operator sees the Escrow it holds, but NOT the offer or the loan.
testCustodianSeesOnlyEscrow : Script ()
testCustodianSeesOnlyEscrow = do
  env@Env{..} <- setup
  _loanCid <- originate env
  opLoans <- query @Loan operator
  assertMsg "custodian sees no loan" (null opLoans)
  opOffers <- query @LoanOffer operator
  assertMsg "custodian sees no offer" (null opOffers)
  opEscrows <- query @Escrow operator
  assertMsg "custodian sees the escrow it holds" (length opEscrows == 1)
  regLoans <- query @Loan regulator
  assertMsg "regulator still sees the loan" (length regLoans == 1)

-- Offer visibility: lender/borrower/regulator see the offer; outsider and custodian do not.
testOfferVisibility : Script ()
testOfferVisibility = do
  env@Env{..} <- setup
  lenderCash <- mintHolding registry lender usd 100.0
  cashAlloc <- fundAllocation registry rulesCid (mkSpec lender borrower lender usd 100.0) [lenderCash]
  _offer <- makeOffer env cashAlloc
  let count p = length <$> query @LoanOffer p
  count lender >>= \n -> assertMsg "lender sees offer" (n == 1)
  count borrower >>= \n -> assertMsg "borrower sees offer" (n == 1)
  count regulator >>= \n -> assertMsg "regulator sees offer" (n == 1)
  count outsider >>= \n -> assertMsg "outsider sees no offer" (n == 0)
  count operator >>= \n -> assertMsg "custodian sees no offer" (n == 0)

-- Liquidation: healthy mark rejected; real breach seizes collateral to the lender.
testLiquidationRequiresBreach : Script ()
testLiquidationRequiresBreach = do
  env@Env{..} <- setup
  loanCid <- originate env

  -- Healthy mark (value 150 -> LTV 66.7%) must be rejected (fails at the guard).
  submitMustFail lender $ exerciseCmd loanCid Liquidate with
    currentCollateralValue = 150.0
    collateralExtraArgs = emptyExtraArgs

  -- Price shock (value 90 -> LTV 111%) breaches the 90% threshold and liquidates.
  closedCid <- submit (actAs [lender] <> readAs [operator, registry]) $ exerciseCmd loanCid Liquidate with
    currentCollateralValue = 90.0
    collateralExtraArgs = emptyExtraArgs

  balanceOf lender tbill >>= \b -> assertMsg "collateral seized to lender" (b == 150.0)
  balanceOf borrower tbill >>= \b -> assertMsg "borrower has no collateral" (b == 0.0)
  closed <- queryContractId regulator closedCid
  assertMsg "regulator sees Liquidated record"
    (optional False (\c -> c.reason == "Liquidated" && not c.collateralReleased) closed)

-- Escrow is not frozen at/after maturity: a defaulting borrower can still be liquidated once the
-- loan has matured (release mints a fresh short-lived allocation).
testLiquidationAfterMaturity : Script ()
testLiquidationAfterMaturity = do
  env@Env{..} <- setup
  loanCid <- originate env
  setTime (addRelTime deadline (days 1))
  closedCid <- submit (actAs [lender] <> readAs [operator, registry]) $ exerciseCmd loanCid Liquidate with
    currentCollateralValue = 90.0
    collateralExtraArgs = emptyExtraArgs
  balanceOf lender tbill >>= \b -> assertMsg "collateral seized after maturity" (b == 150.0)
  closed <- queryContractId regulator closedCid
  assertMsg "regulator sees Liquidated record" (optional False (\c -> c.reason == "Liquidated") closed)

-- Security: once collateral is escrowed (executed into the operator's holding), the borrower cannot
-- reclaim it via the standard sender-controlled Allocation_Withdraw (the allocation is consumed).
testCollateralNotBorrowerWithdrawable : Script ()
testCollateralNotBorrowerWithdrawable = do
  Env{..} <- setup
  borrowerColl <- mintHolding registry borrower tbill 150.0
  collAlloc <- fundAllocation registry rulesCid (mkSpec borrower operator operator tbill 150.0) [borrowerColl]
  _ <- submit (actAs [borrower, operator]) $
    exerciseCmd collAlloc Allocation_ExecuteTransfer with extraArgs = emptyExtraArgs

  -- The exploit attempt: withdraw the now-consumed collateral allocation.
  submitMustFail borrower $ exerciseCmd collAlloc Allocation_Withdraw with extraArgs = emptyExtraArgs

  balanceOf borrower tbill >>= \b -> assertMsg "borrower cannot hold collateral" (b == 0.0)
  balanceOf operator tbill >>= \b -> assertMsg "collateral escrowed with operator" (b == 150.0)

-- Security: the escrow operator must be a neutral third party. An offer naming a counterparty as
-- operator is rejected at creation.
testOperatorMustBeNeutral : Script ()
testOperatorMustBeNeutral = do
  Env{..} <- setup
  lenderCash <- mintHolding registry lender usd 100.0
  cashAlloc <- fundAllocation registry rulesCid (mkSpec lender borrower lender usd 100.0) [lenderCash]
  let mkOfferWith op = createCmd LoanOffer with
        lender; borrower; regulator; operator = op
        cashAllocationCid = cashAlloc
        cashInstrumentId = usd; principal = 100.0; interest = 5.0
        collateralInstrumentId = tbill; collateralQuantity = 150.0
        liquidationThresholdLtv = 90.0; maturity = deadline
  submitMustFail lender $ mkOfferWith lender     -- operator = lender rejected
  submitMustFail lender $ mkOfferWith borrower   -- operator = borrower rejected

-- Withdraw: lender pulls an unaccepted offer and refunds the escrowed principal via the standard
-- sender-controlled Allocation_Withdraw.
testWithdrawRefunds : Script ()
testWithdrawRefunds = do
  env@Env{..} <- setup
  lenderCash <- mintHolding registry lender usd 100.0
  cashAlloc <- fundAllocation registry rulesCid (mkSpec lender borrower lender usd 100.0) [lenderCash]
  offerCid <- makeOffer env cashAlloc

  balanceOf lender usd >>= \b -> assertMsg "principal escrowed" (b == 0.0)

  submit lender $ exerciseCmd offerCid Withdraw
  _ <- submit lender $ exerciseCmd cashAlloc Allocation_Withdraw with extraArgs = emptyExtraArgs
  balanceOf lender usd >>= \b -> assertMsg "principal refunded" (b == 100.0)
  borrowerOffers <- query @LoanOffer borrower
  assertMsg "offer withdrawn" (null borrowerOffers)
