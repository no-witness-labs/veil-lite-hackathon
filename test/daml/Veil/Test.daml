module Veil.Test where

import Daml.Script
import DA.Assert ((===))
import DA.List (sort)
import Veil

tbill : Text
tbill = "Tokenized T-Bill / MMF"

-- Allocate the demo parties and seed holdings: lender funds with 100 cash,
-- borrower holds 105 treasury cash plus 150 collateral units.
setup : Script (Party, Party, Party, ContractId CashHolding, ContractId CashHolding, ContractId CollateralHolding)
setup = do
  lender <- allocateParty "Lender"
  borrower <- allocateParty "Borrower"
  regulator <- allocateParty "Regulator"
  lenderCash <- submit lender do createCmd CashHolding with owner = lender; amount = 100.0
  borrowerCash <- submit borrower do createCmd CashHolding with owner = borrower; amount = 105.0
  borrowerColl <- submit borrower do createCmd CollateralHolding with owner = borrower; asset = tbill; quantity = 150.0
  pure (lender, borrower, regulator, lenderCash, borrowerCash, borrowerColl)

makeOffer : Party -> Party -> Party -> ContractId CashHolding -> Script (ContractId LoanOffer)
makeOffer lender borrower regulator lenderCash =
  submit lender do
    exerciseCmd lenderCash MakeOffer with
      borrower; regulator
      principal = 100.0
      interest = 5.0
      collateralAsset = tbill
      collateralQuantity = 150.0
      maturity = "2026-07-13"
      liquidationThresholdLtv = 90.0

cashAmounts : Party -> Script [Decimal]
cashAmounts p = do
  hs <- query @CashHolding p
  pure $ sort [h.amount | (_, h) <- hs]

testFullLifecycle : Script ()
testFullLifecycle = script do
  (lender, borrower, regulator, lenderCash, borrowerCash, borrowerColl) <- setup

  -- Borrower starts with tokenized collateral.
  borrowerCollBefore <- query @CollateralHolding borrower
  length borrowerCollBefore === 1

  offerCid <- makeOffer lender borrower regulator lenderCash

  -- Funding left the lender (offer is pre-funded).
  lenderCashAfterOffer <- query @CashHolding lender
  length lenderCashAfterOffer === 0
  -- Regulator (observer) can see the offer; outsider cannot.
  query @LoanOffer regulator >>= \o -> length o === 1

  loanCid <- submit borrower do
    exerciseCmd offerCid Accept with collateralCid = borrowerColl

  -- Accepting locks/encumbers collateral and delivers the principal.
  Some loan <- queryContractId borrower loanCid
  loan.collateralLocked === True
  loan.principal === 100.0
  loan.interest === 5.0
  -- Canonical numbers as values: repayment = 105, initial LTV = 66.7% (collateral = 1.5x principal).
  (loan.principal + loan.interest) === 105.0
  loan.collateralQuantity === loan.principal * 1.5
  -- Regulator can see the active loan.
  query @Loan regulator >>= \l -> length l === 1
  borrowerCollLocked <- query @CollateralHolding borrower
  length borrowerCollLocked === 0
  cashAmounts borrower >>= \a -> a === [100.0, 105.0]

  -- Outsider sees nothing throughout.
  outsider <- allocateParty "Outsider"
  query @Loan outsider >>= \l -> length l === 0

  closedCid <- submit borrower do
    exerciseCmd loanCid Repay with repaymentCid = borrowerCash

  -- Repayment closes the loan and releases collateral to the borrower.
  query @Loan borrower >>= \l -> length l === 0
  borrowerCollReleased <- query @CollateralHolding borrower
  length borrowerCollReleased === 1
  Some closed <- queryContractId regulator closedCid
  closed.reason === "Repaid"
  closed.collateralReleased === True

  -- Double-entry settled: lender +5 (105), borrower keeps 100 principal.
  cashAmounts lender >>= \a -> a === [105.0]
  cashAmounts borrower >>= \a -> a === [100.0]
  query @LoanClosed outsider >>= \c -> length c === 0

testLiquidationRequiresBreach : Script ()
testLiquidationRequiresBreach = script do
  (lender, borrower, regulator, lenderCash, _, borrowerColl) <- setup
  offerCid <- makeOffer lender borrower regulator lenderCash
  loanCid <- submit borrower do exerciseCmd offerCid Accept with collateralCid = borrowerColl

  -- Non-stakeholders cannot see the active loan (outsider and an oracle party).
  outsider <- allocateParty "Outsider"
  oracle <- allocateParty "Oracle"
  query @Loan outsider >>= \l -> length l === 0
  query @Loan oracle >>= \l -> length l === 0

  -- Healthy mark (LTV 66.7%) must NOT permit liquidation.
  submitMustFail lender do exerciseCmd loanCid Liquidate with currentCollateralValue = 150.0
  query @Loan borrower >>= \l -> length l === 1

  -- Price shock (LTV ~107%) breaches the threshold and seizes collateral.
  closedCid <- submit lender do exerciseCmd loanCid Liquidate with currentCollateralValue = 93.0
  query @Loan borrower >>= \l -> length l === 0
  Some closed <- queryContractId borrower closedCid
  closed.reason === "Liquidated"
  closed.collateralReleased === False
  -- Collateral was seized to the lender, not released to the borrower.
  query @CollateralHolding lender >>= \c -> length c === 1
  query @CollateralHolding borrower >>= \c -> length c === 0
  -- Outsider still sees no liquidation-relevant state.
  query @LoanClosed outsider >>= \c -> length c === 0

testWithdrawRefunds : Script ()
testWithdrawRefunds = script do
  (lender, borrower, regulator, lenderCash, _, _) <- setup
  offerCid <- makeOffer lender borrower regulator lenderCash
  query @CashHolding lender >>= \c -> length c === 0
  _ <- submit lender do exerciseCmd offerCid Withdraw
  -- Principal refunded to the lender.
  cashAmounts lender >>= \a -> a === [100.0]
  query @LoanOffer borrower >>= \o -> length o === 0

-- Authorization: each choice can only be exercised by its controller.
testOnlyControllerCanAct : Script ()
testOnlyControllerCanAct = script do
  (lender, borrower, regulator, lenderCash, borrowerCash, borrowerColl) <- setup
  outsider <- allocateParty "Outsider"
  offerCid <- makeOffer lender borrower regulator lenderCash

  -- Only the lender may withdraw the offer.
  submitMustFail borrower do exerciseCmd offerCid Withdraw
  -- Only the borrower may accept (a non-stakeholder cannot).
  submitMustFail outsider do exerciseCmd offerCid Accept with collateralCid = borrowerColl

  loanCid <- submit borrower do exerciseCmd offerCid Accept with collateralCid = borrowerColl

  -- Only the borrower may repay; only the lender may liquidate.
  submitMustFail lender do exerciseCmd loanCid Repay with repaymentCid = borrowerCash
  submitMustFail borrower do exerciseCmd loanCid Liquidate with currentCollateralValue = 93.0

-- Validation guards: choice bodies reject inconsistent inputs.
testValidationGuards : Script ()
testValidationGuards = script do
  lender <- allocateParty "Lender"
  borrower <- allocateParty "Borrower"
  regulator <- allocateParty "Regulator"
  lenderCash <- submit lender do createCmd CashHolding with owner = lender; amount = 100.0

  -- MakeOffer cannot fund more principal than the cash holds.
  submitMustFail lender do
    exerciseCmd lenderCash MakeOffer with
      borrower; regulator
      principal = 200.0
      interest = 5.0
      collateralAsset = tbill
      collateralQuantity = 150.0
      maturity = "2026-07-13"
      liquidationThresholdLtv = 90.0

  offerCid <- submit lender do
    exerciseCmd lenderCash MakeOffer with
      borrower; regulator
      principal = 100.0
      interest = 5.0
      collateralAsset = tbill
      collateralQuantity = 150.0
      maturity = "2026-07-13"
      liquidationThresholdLtv = 90.0

  -- Accept rejects collateral that doesn't match the offered quantity.
  wrongColl <- submit borrower do createCmd CollateralHolding with owner = borrower; asset = tbill; quantity = 100.0
  submitMustFail borrower do exerciseCmd offerCid Accept with collateralCid = wrongColl

  -- A matching holding is accepted; then repayment cannot be underfunded.
  goodColl <- submit borrower do createCmd CollateralHolding with owner = borrower; asset = tbill; quantity = 150.0
  loanCid <- submit borrower do exerciseCmd offerCid Accept with collateralCid = goodColl
  shortCash <- submit borrower do createCmd CashHolding with owner = borrower; amount = 50.0
  submitMustFail borrower do exerciseCmd loanCid Repay with repaymentCid = shortCash

-- Borrower carves the exact repayment out of an oversized wallet in
-- an owner-only Split transaction (no lender/regulator informee), so Repay only
-- ever fetches a 105 holding — value both sides already agreed — instead of
-- divulging the borrower's full treasury balance. Repay now rejects any holding
-- whose amount is not exactly principal + interest.
testRepayExactAmountViaSplit : Script ()
testRepayExactAmountViaSplit = script do
  (lender, borrower, regulator, lenderCash, _, borrowerColl) <- setup
  offerCid <- makeOffer lender borrower regulator lenderCash
  loanCid <- submit borrower do exerciseCmd offerCid Accept with collateralCid = borrowerColl

  -- An oversized treasury wallet cannot be used to repay directly: the exact-amount
  -- guard rejects it, so Repay never fetches (and divulges) the larger balance.
  oversized <- submit borrower do createCmd CashHolding with owner = borrower; amount = 5000.0
  submitMustFail borrower do exerciseCmd loanCid Repay with repaymentCid = oversized

  -- The borrower splits exactly the 105 repayment in a private, owner-only tx.
  (exactCid, remainderCid) <- submit borrower do exerciseCmd oversized Split with splitAmount = 105.0

  -- Split conserves value: 105 exact + 4895 remainder, both owned by the borrower.
  Some exact <- queryContractId borrower exactCid
  exact.amount === 105.0
  Some remainder <- queryContractId borrower remainderCid
  remainder.amount === 4895.0

  -- Repay with the exact holding succeeds and closes the loan.
  closedCid <- submit borrower do exerciseCmd loanCid Repay with repaymentCid = exactCid
  Some closed <- queryContractId regulator closedCid
  closed.reason === "Repaid"
  closed.collateralReleased === True

  -- Double-entry settled: lender +105; borrower keeps the 100 drawn principal, the
  -- 105 seed wallet, and the 4895 split remainder. Collateral is released, not cash.
  cashAmounts lender >>= \a -> a === [105.0]
  cashAmounts borrower >>= \a -> a === [100.0, 105.0, 4895.0]
  query @CollateralHolding borrower >>= \c -> length c === 1

-- Split guards: the owner-only Split rejects non-positive amounts and refuses to
-- split off the entire balance (splitAmount must be strictly less than amount).
testSplitGuards : Script ()
testSplitGuards = script do
  borrower <- allocateParty "Borrower"
  wallet <- submit borrower do createCmd CashHolding with owner = borrower; amount = 105.0
  submitMustFail borrower do exerciseCmd wallet Split with splitAmount = 0.0
  submitMustFail borrower do exerciseCmd wallet Split with splitAmount = 105.0
  submitMustFail borrower do exerciseCmd wallet Split with splitAmount = 200.0
